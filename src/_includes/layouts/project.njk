---
layout: layouts/base.njk
---
<article class="project-page">
  <a class="back-link" href="/portfolio/">← Back to portfolio</a>

  <header class="project-header">
    <p class="eyebrow">Project</p>
    <h1 class="display">{{ name or title }}</h1>
    {% if description %}<p class="lede">{{ description }}</p>{% endif %}
  </header>

  {% if embed %}
  <div class="embed-wrap">
    <iframe
      class="embed-frame"
      src="{{ embed }}"
      title="{{ name or title }}"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>
  {% else %}
  <div class="embed-placeholder">
    <p class="embed-placeholder-title">Interactive content goes here</p>
    <p class="muted">
      In Storyline, choose <strong>Publish ▸ Web</strong>. Drop the published folder into
      <code>src/projects-content/{{ page.fileSlug }}/</code>, then add
      <code>embed: /projects-content/{{ page.fileSlug }}/story.html</code>
      to this project's front matter.
    </p>
  </div>
  {% endif %}

  {% if content %}
  <div class="prose project-body">
    {{ content | safe }}
  </div>
  {% endif %}
</article>
